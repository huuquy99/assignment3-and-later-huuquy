#!/bin/sh
# aesdsocket-start-stop: init script to start/stop the aesdsocket daemon
# Usage: aesdsocket-start-stop {start|stop}

DAEMON=/usr/bin/aesdsocket
DAEMON_NAME=aesdsocket
PIDFILE=/var/run/${DAEMON_NAME}.pid

case "$1" in
    start)
        echo "Starting ${DAEMON_NAME}"
        # start-stop-daemon: start or stop a daemon process
        #   --start           : start the daemon
        #   --name            : match process by name (used for duplicate detection)
        #   --make-pidfile    : write the daemon's PID to PIDFILE
        #   --pidfile         : path to the PID file
        #   --background      : force the process into the background (not needed with -d, but kept for safety)
        #   --exec            : path to the executable to run
        #   --               : separator; arguments after this are passed to the daemon
        #   -d                : tell aesdsocket to daemonize itself
        start-stop-daemon --start \
                          --name  ${DAEMON_NAME} \
                          --make-pidfile \
                          --pidfile ${PIDFILE} \
                          --background \
                          --exec ${DAEMON} \
                          -- -d
        ;;

    stop)
        echo "Stopping ${DAEMON_NAME}"
        # start-stop-daemon: stop the daemon
        #   --stop            : send a signal to the matching process
        #   --name            : match process by name
        #   --pidfile         : use PID file to identify the process
        #   --signal TERM     : send SIGTERM for graceful shutdown
        #                       aesdsocket catches SIGTERM, closes sockets, deletes /var/tmp/aesdsocketdata
        #   --retry 5         : wait up to 5 seconds for the process to exit
        start-stop-daemon --stop \
                          --name    ${DAEMON_NAME} \
                          --pidfile ${PIDFILE} \
                          --signal  TERM \
                          --retry   5
        # Remove the PID file after the daemon exits
        rm -f ${PIDFILE}
        ;;

    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac

exit 0
